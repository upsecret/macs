# ============================================================
# MACS System - 환경변수 예시
# 사용법: cp .env.example .env  후 값 조정 → docker compose up -d
# ============================================================

# Oracle 서비스명 (리스너에 등록된 값)
# 기본 FREE (gvenzl/oracle-free 컨테이너 CDB)
# 환경에 따라 PDB(FREEPDB1)로 붙여야 하면 아래 주석 해제
ORACLE_SERVICE_NAME=FREE
# ORACLE_SERVICE_NAME=FREEPDB1

# Bootstrap admin 사번 (admin-server 기동 시 PERMISSION에 자동 UPSERT)
# MACS_BOOTSTRAP_ADMIN_ENABLED=true
# MACS_BOOTSTRAP_ADMIN_EMPLOYEE_NUMBER=2078432
# MACS_BOOTSTRAP_ADMIN_APP_NAME=portal
