# MACS 환경 설정 예시. 실제 값은 배포 파이프라인에서 주입한다.
# 이 파일은 key 목록 참고용이고, 실제 값이 들어간 .env 는 커밋하지 않는다.

# Auth-server JWT 서명 키 (HMAC-SHA)
JWT_SECRET=

# Oracle DB 접속 정보
ORACLE_PASSWORD=

# Gateway 가 외부에 노출되는 host (portal API Docs 뷰어의 curl 예시 base URL)
GATEWAY_EXTERNAL_HOST=

# SSL 인증서 경로 (사내 배포 환경에서만 사용)
HYNIX_CRT_PATH=
